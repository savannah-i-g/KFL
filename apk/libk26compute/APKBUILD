# Contributor: Savannah Goring <contact@federatedindustrial.com>
# Maintainer: Savannah Goring <contact@federatedindustrial.com>
pkgname=libk26compute
pkgver=0.4.1
pkgrel=0
pkgdesc="K26 compute library — vector/matrix, statistics, ODE, optimisation, RNG"
url="https://github.com/Federated-Industrial-Laboratories/KFL"
arch="x86_64"
license="MIT"
# Pure-C static archive; no runtime deps beyond libm (transitive via
# the consumer's link line).
makedepends="
    build-base
"
options="!check"
source=""
builddir="$startdir/../../libk26compute"

build() {
    cd "$builddir"
    make
}

package() {
    cd "$builddir"
    make install DESTDIR="$pkgdir" PREFIX=/usr
    install -Dm644 "$startdir"/../../LICENSE \
        "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}
