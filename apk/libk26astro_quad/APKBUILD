# Contributor: Savannah Goring <contact@federatedindustrial.com>
# Maintainer: Savannah Goring <contact@federatedindustrial.com>
pkgname=libk26astro_quad
pkgver=0.4.1
pkgrel=0
pkgdesc="adaptive 1-D numerical quadrature (QUADPACK, jacobwilliams fork)"
url="https://github.com/Federated-Industrial-Laboratories/KFL"
arch="x86_64"
# K26-authored wrapper code is MIT; vendored QUADPACK is BSD-3-Clause.
license="MIT AND BSD-3-Clause"
makedepends="
    build-base
    gfortran
"
depends="libgfortran"
options="!check"
source=""
builddir="$startdir/../../libk26astro_quad"

build() {
    cd "$builddir"
    make
}

package() {
    cd "$builddir"
    make install DESTDIR="$pkgdir" PREFIX=/usr
    install -Dm644 "$startdir"/../../LICENSE \
        "$pkgdir"/usr/share/licenses/$pkgname/LICENSE 2>/dev/null || true
}
