# Contributor: Savannah Goring <contact@federatedindustrial.com>
# Maintainer: Savannah Goring <contact@federatedindustrial.com>
pkgname=libk26astro_rt
pkgver=0.4.1
pkgrel=0
pkgdesc="runtime world (composes core/body/ephem/grav, MERCURIUS, snapshot)"
url="https://github.com/Federated-Industrial-Laboratories/KFL"
arch="x86_64"
license="MIT"
makedepends="
    build-base
    libk26astro_core
    libk26astro_body
    libk26astro_ephem
    libk26astro_conics
    libk26astro_grav
    libk26tick
    libk26m3d
"
options="!check"
source=""
builddir="$startdir/../../libk26astro_rt"

build() {
    cd "$builddir"
    make
}

package() {
    cd "$builddir"
    make install DESTDIR="$pkgdir" PREFIX=/usr
    install -Dm644 "$startdir"/../../LICENSE \
        "$pkgdir"/usr/share/licenses/$pkgname/LICENSE 2>/dev/null || true
}
